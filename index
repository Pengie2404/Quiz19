      explanation: "B is correct. Extension risk is the risk that prepayments come in SLOWER than expected (e.g., when rates rise, fewer borrowers refinance), extending the expected life/duration of the MBS. Contraction risk is the opposite — prepayments faster than expected.",
      explanationVN: "Extension risk = rủi ro trả trước (prepayment) diễn ra CHẬM HƠN dự kiến (VD: khi lãi suất tăng, ít người vay tái cấp vốn hơn) → kéo DÀI THÊM thời gian đáo hạn/duration thực tế của MBS. Contraction risk = ngược lại, trả trước NHANH HƠN dự kiến (thường khi lãi suất giảm, nhiều người tái cấp vốn) → RÚT NGẮN thời gian đáo hạn."
    },
    {
      q: "A sequential pay security is structured with three tranches: A, B, and C. Tranche A receives principal first, followed by Tranche B, and finally Tranche C. An investor concerned about extension risk would most likely prefer:",
      options: ["Tranche A.", "Tranche B.", "Tranche C."],
      correct: 0,
      explanation: "A is correct. An investor worried about extension risk (principal being repaid too slowly) wants the tranche that gets repaid SOONEST. In a sequential-pay structure, Tranche A receives principal payments first, making it the shortest and least exposed to extension risk.",
      explanationVN: "Nhà đầu tư lo ngại về extension risk (sợ vốn gốc được trả LÂU hơn dự kiến) sẽ muốn chọn tranche được HOÀN TRẢ GỐC SỚM NHẤT. Trong cấu trúc sequential-pay (trả tuần tự), Tranche A luôn nhận gốc TRƯỚC TIÊN → có kỳ hạn ngắn nhất và ít bị ảnh hưởng bởi extension risk nhất trong 3 tranche."
    },
    {
      q: "For investors in commercial mortgage-backed securities, balloon risk in commercial mortgages results in:",
      options: ["call risk.", "extension risk.", "contraction risk."],
      correct: 1,
      explanation: "B is correct. Balloon risk is the risk that a commercial borrower cannot refinance the large balloon payment due at maturity, resulting in default. This is typically resolved through a workout period that EXTENDS the loan's term under modified terms — making balloon risk a source of extension risk for CMBS investors, not contraction or call risk.",
      explanationVN: "Balloon risk = rủi ro bên vay thương mại KHÔNG THỂ tái cấp vốn cho khoản thanh toán balloon (dồn gốc) lớn đến hạn cuối kỳ → dẫn đến vỡ nợ (default). Vấn đề này thường được xử lý bằng cách GIA HẠN thời gian vay ('workout period') theo điều khoản điều chỉnh → vì vậy balloon risk chính là một dạng của EXTENSION RISK đối với nhà đầu tư CMBS, không phải call risk hay contraction risk."
    }
  ]
};

const ALL_MODULES = [MODULE_7, MODULE_8, MODULE_9, MODULE_10, MODULE_11, MODULE_12, MODULE_13, MODULE_14, MODULE_15, MODULE_16, MODULE_17, MODULE_18, MODULE_19];
const STORAGE_KEY = "cfa4_quiz_s7s21_v1";

let state = {
  session: null,        // current quiz session object
  reviewFilter: "all",
};

// ---------- Persistence ----------
function loadProgress(){
  try{
    const raw = localStorage.getItem(STORAGE_KEY);
    if(!raw) return { attempts: {}, wrongIds: {} };
    return JSON.parse(raw);
  }catch(e){
    return { attempts: {}, wrongIds: {} };
  }
}
function saveProgress(p){
  try{ localStorage.setItem(STORAGE_KEY, JSON.stringify(p)); }catch(e){}
}
let progress = loadProgress();

// ---------- Build global flat question index ----------
// Each question gets a unique id: moduleId + "_" + index
function buildFlatQuestions(moduleFilter){
  const out = [];
  ALL_MODULES.forEach(mod=>{
    if(moduleFilter && !moduleFilter.includes(mod.id)) return;
    mod.questions.forEach((q, idx)=>{
      out.push({
        uid: mod.id + "_" + idx,
        moduleId: mod.id,
        moduleTitle: mod.title,
        moduleColor: mod.color,
        ...q
      });
    });
  });
  return out;
}

function shuffle(arr){
  const a = arr.slice();
  for(let i=a.length-1;i>0;i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

// ---------- Home screen rendering ----------
function renderHome(){
  const grid = document.getElementById("module-grid");
  grid.innerHTML = "";
  let totalDone = 0, totalCorrect = 0, totalAnswered = 0;

  ALL_MODULES.forEach(mod=>{
    const card = document.createElement("div");
    card.className = "module-card";
    card.style.setProperty("--mc", mod.color);
    card.onclick = () => startModuleQuiz(mod.id);

    let modAnswered = 0, modCorrect = 0;
    mod.questions.forEach((q, idx)=>{
      const uid = mod.id + "_" + idx;
      const att = progress.attempts[uid];
      if(att){
        modAnswered++;
        if(att.correct) modCorrect++;
      }
    });
    totalAnswered += modAnswered;
    totalCorrect += modCorrect;
    if(modAnswered > 0) totalDone++;

    const pct = mod.questions.length ? Math.round((modAnswered/mod.questions.length)*100) : 0;

    card.innerHTML = `
      <div class="num-chip" style="color:${mod.color}; border-color:${mod.color}55;">${mod.id.replace('m','S.')}</div>
      <div class="info">
        <div class="title">${mod.title}</div>
        <div class="sub">${mod.subtitle}</div>
      </div>
      <div class="meta">
        <span class="qcount">${mod.questions.length} câu</span>
        ${modAnswered>0 ? modCorrect+'/'+modAnswered+' đúng' : 'Chưa làm'}
      </div>
      <div class="progress-bar" style="width:${pct}%;"></div>
    `;
    grid.appendChild(card);
  });

  document.getElementById("stat-total").textContent = ALL_MODULES.reduce((s,m)=>s+m.questions.length,0);
  document.getElementById("stat-done").textContent = totalAnswered;
  document.getElementById("stat-avg").textContent = totalAnswered>0 ? Math.round((totalCorrect/totalAnswered)*100)+"%" : "—";
}

// ---------- Screen switching ----------
function showScreen(name){
  document.getElementById("screen-home").classList.toggle("hidden", name!=="home");
  document.getElementById("screen-quiz").classList.toggle("hidden", name!=="quiz");
  document.getElementById("screen-result").classList.toggle("hidden", name!=="result");
  window.scrollTo({top:0, behavior:"smooth"});
}

function goHome(){
  renderHome();
  showScreen("home");
}

// ---------- Starting a quiz session ----------
function createSession(questions, title, sub){
  state.session = {
    title, sub,
    questions,
    current: 0,
    answers: {}, // uid -> { selected, correct }
  };
}

function startModuleQuiz(modId){
  const mod = ALL_MODULES.find(m=>m.id===modId);
  const qs = buildFlatQuestions([modId]);
  createSession(qs, mod.title, mod.subtitle + " · " + qs.length + " câu");
  renderQuizScreen();
  showScreen("quiz");
}

function startFullTest(){
  const qs = shuffle(buildFlatQuestions(null));
  createSession(qs, "Full Test — Fixed Income & Derivatives", "Toàn bộ Fixed Income & Derivatives · random");
  renderQuizScreen();
  showScreen("quiz");
}

function startWeakReview(){
  const wrongUids = Object.keys(progress.attempts).filter(uid => progress.attempts[uid] && !progress.attempts[uid].correct);
  if(wrongUids.length === 0){
    showToast("🎉 Chưa có câu sai nào được ghi nhận — làm vài bộ trước nha!");
    return;
  }
  const all = buildFlatQuestions(null);
  const qs = shuffle(all.filter(q => wrongUids.includes(q.uid)));
  createSession(qs, "Ôn lại câu sai", qs.length + " câu bạn đã từng làm sai");
  renderQuizScreen();
  showScreen("quiz");
}

function retrySame(){
  if(!state.session) return goHome();
  const qs = shuffle(state.session.questions);
  createSession(qs, state.session.title, state.session.sub);
  renderQuizScreen();
  showScreen("quiz");
}

function resetProgress(){
  if(!confirm("Xoá toàn bộ tiến trình đã lưu? (không thể hoàn tác)")) return;
  progress = { attempts: {}, wrongIds: {} };
  saveProgress(progress);
  renderHome();
  showToast("Đã xoá tiến trình.");
}

function exitQuiz(){
  if(!confirm("Thoát bộ câu hỏi hiện tại? Tiến trình các câu đã trả lời sẽ được lưu.")) return;
  goHome();
}

// ---------- Quiz rendering ----------
function renderQuizScreen(){
  const s = state.session;
  document.getElementById("quiz-title").textContent = s.title;
  document.getElementById("quiz-sub").textContent = s.sub;
  renderQuestion();
}

function renderQuestion(){
  const s = state.session;
  const q = s.questions[s.current];
  const total = s.questions.length;

  // progress bar
  const pct = Math.round(((s.current)/total)*100);
  document.getElementById("progress-fill").style.width = pct + "%";
  document.getElementById("progress-text").textContent = `Câu ${s.current+1} / ${total}`;

  let correctCount=0, wrongCount=0;
  Object.values(s.answers).forEach(a=>{ a.correct ? correctCount++ : wrongCount++; });
  document.getElementById("progress-score").textContent = `✓ ${correctCount} · ✗ ${wrongCount}`;

  document.getElementById("q-tag").textContent = `${q.moduleTitle.toUpperCase()}`;
  document.getElementById("q-tag").style.color = q.moduleColor;
  document.getElementById("q-text").textContent = q.q;

  const optList = document.getElementById("opt-list");
  optList.innerHTML = "";
  const letters = ["A","B","C","D","E"];
  const existingAnswer = s.answers[q.uid];

  q.options.forEach((opt, idx)=>{
    const div = document.createElement("div");
    div.className = "opt";
    div.innerHTML = `<span class="opt-letter">${letters[idx]}</span><span>${opt}</span>`;
    if(existingAnswer){
      div.classList.add("locked");
      if(idx === q.correct) div.classList.add("correct");
      if(idx === existingAnswer.selected && idx !== q.correct) div.classList.add("wrong");
      if(idx !== q.correct && idx !== existingAnswer.selected) div.classList.add("dim");
    } else {
      div.onclick = () => selectAnswer(idx);
    }
    optList.appendChild(div);
  });

  const explainBox = document.getElementById("explain-box");
  const explainText = document.getElementById("explain-text");
  const explainTextVN = document.getElementById("explain-text-vn");
  if(existingAnswer){
    explainText.textContent = q.explanation;
    if(explainTextVN) explainTextVN.textContent = q.explanationVN || "";
    explainBox.classList.add("show");
  } else {
    explainBox.classList.remove("show");
  }

  document.getElementById("btn-prev").disabled = s.current === 0;
  const isLast = s.current === total-1;
  document.getElementById("btn-next").textContent = isLast ? "Xem kết quả →" : "Câu tiếp →";
  document.getElementById("btn-next").disabled = !existingAnswer;
}

function selectAnswer(idx){
  const s = state.session;
  const q = s.questions[s.current];
  if(s.answers[q.uid]) return; // already answered, locked

  const isCorrect = idx === q.correct;
  s.answers[q.uid] = { selected: idx, correct: isCorrect };

  // persist to global progress
  progress.attempts[q.uid] = { correct: isCorrect, ts: Date.now() };
  saveProgress(progress);

  renderQuestion();
}

function nextQuestion(){
  const s = state.session;
  if(s.current < s.questions.length - 1){
    s.current++;
    renderQuestion();
  } else {
    showResult();
  }
}
function prevQuestion(){
  const s = state.session;
  if(s.current > 0){
    s.current--;
    renderQuestion();
  }
}

// ---------- Result screen ----------
function showResult(){
  const s = state.session;
  const total = s.questions.length;
  let correct = 0;
  s.questions.forEach(q=>{
    const a = s.answers[q.uid];
    if(a && a.correct) correct++;
  });
  const pct = total ? Math.round((correct/total)*100) : 0;

  document.getElementById("result-pct").textContent = pct + "%";
  document.getElementById("result-frac").textContent = `${correct}/${total}`;

  let color, verdict, sub;
  if(pct >= 80){ color="#10b981"; verdict="🔥 Xuất sắc!"; sub="Vững nền tảng rồi, tiếp tục giữ nhịp ôn nha."; }
  else if(pct >= 60){ color="#f59e0b"; verdict="👍 Khá ổn"; sub="Còn vài lỗ hổng, xem lại phần giải thích các câu sai."; }
  else { color="#ef4444"; verdict="📚 Cần ôn lại"; sub="Đọc kỹ phần giải thích, rồi quay lại làm 'Ôn lại câu sai' nhé."; }

  document.getElementById("score-circle").style.borderColor = color;
  document.getElementById("result-pct").style.color = color;
  document.getElementById("result-verdict").textContent = verdict;
  document.getElementById("result-sub").textContent = sub;

  state.reviewFilter = "all";
  document.querySelectorAll(".chip-filter").forEach(c=>c.classList.toggle("active", c.dataset.f==="all"));
  renderReviewList();
  showScreen("result");
}

function setReviewFilter(f){
  state.reviewFilter = f;
  document.querySelectorAll(".chip-filter").forEach(c=>c.classList.toggle("active", c.dataset.f===f));
  renderReviewList();
}

function renderReviewList(){
  const s = state.session;
  const list = document.getElementById("review-list");
  list.innerHTML = "";

  const letters = ["A","B","C","D","E"];
  let items = s.questions.map((q, idx)=>({q, idx, ans: s.answers[q.uid]}));

  if(state.reviewFilter === "bad") items = items.filter(it => it.ans && !it.ans.correct);
  if(state.reviewFilter === "ok") items = items.filter(it => it.ans && it.ans.correct);

  if(items.length === 0){
    list.innerHTML = `<div class="center-empty"><div class="emoji">🤷</div>Không có câu nào trong bộ lọc này.</div>`;
    return;
  }

  items.forEach(({q, idx, ans})=>{
    const div = document.createElement("div");
    const isOk = ans && ans.correct;
    div.className = "review-item " + (ans ? (isOk ? "ok" : "bad") : "");
    const selectedTxt = ans ? `${letters[ans.selected]}. ${q.options[ans.selected]}` : "(chưa trả lời)";
    const correctTxt = `${letters[q.correct]}. ${q.options[q.correct]}`;
    const firstLine = q.q.split("\n")[0];
    div.innerHTML = `
      <div class="ri-top">
        <span style="font-size:.72rem; color:${q.moduleColor}; font-family:'JetBrains Mono',monospace;">${q.moduleTitle}</span>
        <span class="ri-icon">${ans ? (isOk ? "✅" : "❌") : "⬜"}</span>
      </div>
      <div class="ri-q"><b style="color:var(--text)">Câu ${idx+1}:</b> ${firstLine}</div>
      ${!isOk ? `<div class="ri-q" style="margin-top:6px; color:var(--wrong-border)">Bạn chọn: ${selectedTxt}</div>` : ""}
      <div class="ri-q" style="margin-top:4px; color:var(--correct-border)">Đáp án đúng: ${correctTxt}</div>
      <div class="ri-q" style="margin-top:6px; font-style:italic;">${q.explanation}</div>
      ${q.explanationVN ? `<div class="ri-q" style="margin-top:6px; font-style:italic; color:#f59e0b;">🗣️ ${q.explanationVN}</div>` : ""}
    `;
    list.appendChild(div);
  });
}

function reviewMistakes(){
  state.reviewFilter = "bad";
  document.querySelectorAll(".chip-filter").forEach(c=>c.classList.toggle("active", c.dataset.f==="bad"));
  renderReviewList();
  document.getElementById("review-list").scrollIntoView({behavior:"smooth", block:"start"});
}

// ---------- Misc ----------
function toggleQuizMenu(){
  if(!confirm("Thoát bộ câu hỏi hiện tại và xem kết quả ngay (các câu chưa trả lời sẽ tính là sai)?")) return;
  showResult();
}

function showToast(msg){
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  setTimeout(()=>t.classList.remove("show"), 2600);
}

// ---------- Init ----------
renderHome();
showScreen("home");


</script>
